---
import { arrayCards } from '@/utils/data';
import { baseUrl } from '@/utils/functions';
---

<section class='am-container-cards'>
  {
    arrayCards.map(({ id, localImage, repo, title }) => (
      <a class='container' href={repo}>
        <img src={baseUrl(localImage)} alt={title} />
      </a>
    ))
  }
</section>

<style>
  .am-container-cards {
    min-height: 100vh;
    display: grid;
    padding: 1.4vmax;
    gap: 1.4vmax;
    place-content: center;
    place-items: center;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17vmax, 1fr));
  }

  .container {
    min-width: 15vmax;
    width: 100%;
    aspect-ratio: 16 / 9;

    &:hover {
      img {
        transition: filter 0s ease;
        filter: grayscale(0) contrast(1);
      }
    }

    img {
      width: 100%;
      height: 100%;
      border-radius: 0.8vmax;
      object-fit: cover;
      transition: filter 1s ease;
      filter: grayscale(1) contrast(5);
    }
  }
</style>
